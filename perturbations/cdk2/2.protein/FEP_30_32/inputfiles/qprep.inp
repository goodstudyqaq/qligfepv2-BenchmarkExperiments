rl /home/shen/code/Q2/src/QligFEP/FF/AMBER14sb.lib 
rl 30.lib
rl 32_renumber.lib
rprm AMBER14sb_30_32_merged.prm 
! TO DO Change if protein system is used
rp 30_32.pdb 
! solvation - density adapted to membrane proteins
set solvent_pack 2.3
set solute_density 0.05794
boundary 1 1.056 26.335 8.691 25
solvate 1.056 26.335 8.691 25 4 water.pdb
!addbond at1 at2 y
maketop MKC_p 
writetop dualtop.top 
wp top_p.pdb y 
rt dualtop.top
mask none
mask not excluded 
wp complexnotexcluded.pdb y 
q 