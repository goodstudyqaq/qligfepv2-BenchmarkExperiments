rl /home/shen/code/Q2/src/QligFEP/FF/AMBER14sb.lib 
rl 28.lib
rl 29_renumber.lib
rprm AMBER14sb_28_29_merged.prm 
! TO DO Change if protein system is used
rp 28_29.pdb 
! solvation - density adapted to membrane proteins
set solvent_pack 2.3
set solute_density 0.05794
boundary 1 1.155 26.192 8.784 25
solvate 1.155 26.192 8.784 25 4 water.pdb
!addbond at1 at2 y
maketop MKC_p 
writetop dualtop.top 
wp top_p.pdb y 
rt dualtop.top
mask none
mask not excluded 
wp complexnotexcluded.pdb y 
q 