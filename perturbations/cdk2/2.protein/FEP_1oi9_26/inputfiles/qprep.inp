rl /home/shen/code/Q2/src/QligFEP/FF/AMBER14sb.lib 
rl 1oi9.lib
rl 26_renumber.lib
rprm AMBER14sb_1oi9_26_merged.prm 
! TO DO Change if protein system is used
rp 1oi9_26.pdb 
! solvation - density adapted to membrane proteins
set solvent_pack 2.3
set solute_density 0.05794
boundary 1 0.641 26.708 8.792 25
solvate 0.641 26.708 8.792 25 4 water.pdb
!addbond at1 at2 y
maketop MKC_p 
writetop dualtop.top 
wp top_p.pdb y 
rt dualtop.top
mask none
mask not excluded 
wp complexnotexcluded.pdb y 
q 