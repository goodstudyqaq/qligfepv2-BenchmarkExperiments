rl /home/shen/code/Q2/src/QligFEP/FF/AMBER14sb.lib 
rl 32.lib
rl 1h1s_renumber.lib
rprm AMBER14sb_32_1h1s_merged.prm 
! TO DO Change if protein system is used
rp 32_1h1s.pdb 
! solvation - density adapted to membrane proteins
set solvent_pack 2.3
set solute_density 0.05794
boundary 1 1.128 26.379 8.843 25
solvate 1.128 26.379 8.843 25 1 HOH
!addbond at1 at2 y
maketop MKC_p 
writetop dualtop.top 
wp top_p.pdb y 
rt dualtop.top
mask none
mask not excluded 
wp complexnotexcluded.pdb y 
q 